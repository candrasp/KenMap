# Salin file ini jadi .env, lalu sesuaikan.
# Kalau pakai docker-compose.yml yang sudah include Postgres,
# variabel ini otomatis dipakai lewat "environment:" di compose -
# .env di sini opsional, cuma dipakai kalau kamu jalankan `docker compose`
# dan mau override nilai default (password, dsb).

DB_PASSWORD=ganti_password_ini
SESSION_SECRET=5LIgY2ltLOTDxSr68bGsr4dMDDBNKIRO4165JNA6SLs=
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin

# Kalau menjalankan backend LANGSUNG di host (npm run dev, bukan docker-compose),
# override DATABASE_URL manual di sini:
# DATABASE_URL=postgres://kenmap:ganti_password_ini@localhost:5432/kenmap


#Ini adalah PORT untuk mengakses aplikasi.
#Jika port 3000 telah di gunakan bisa kamu ganti port yang lain.
PORT=3000 
